<?xml version="1.0" ?>
<sdf version="1.10">
  <model name="boxbot">
    <pose>0 0 0.1 0 0 0</pose>

    <!-- Chassis -->
    <link name="base_link">
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.02</ixx><iyy>0.04</iyy><izz>0.05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry><box><size>0.30 0.20 0.08</size></box></geometry>
      </collision>
      <visual name="base_visual">
        <geometry><box><size>0.30 0.20 0.08</size></box></geometry>
      </visual>
    </link>

    <!-- Wheel helper: cylinder axis is Z by default, rotate about X to make it a wheel -->
    <!-- Front left -->
    <link name="fl_wheel_link">
      <pose>0.11 0.11 0.05 0 0 0</pose>
      <inertial><mass>0.2</mass></inertial>
      <collision name="fl_wheel_collision">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </collision>
      <visual name="fl_wheel_visual">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Rear left -->
    <link name="rl_wheel_link">
      <pose>-0.11 0.11 0.05 0 0 0</pose>
      <inertial><mass>0.2</mass></inertial>
      <collision name="rl_wheel_collision">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </collision>
      <visual name="rl_wheel_visual">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Front right -->
    <link name="fr_wheel_link">
      <pose>0.11 -0.11 0.05 0 0 0</pose>
      <inertial><mass>0.2</mass></inertial>
      <collision name="fr_wheel_collision">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </collision>
      <visual name="fr_wheel_visual">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Rear right -->
    <link name="rr_wheel_link">
      <pose>-0.11 -0.11 0.05 0 0 0</pose>
      <inertial><mass>0.2</mass></inertial>
      <collision name="rr_wheel_collision">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </collision>
      <visual name="rr_wheel_visual">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Wheel joints (pose = wheel location; axis = axle direction, Y) -->
    <joint name="fl_wheel_joint" type="revolute">
      <pose>0.11 0.11 0.05 0 0 0</pose>
      <parent>base_link</parent><child>fl_wheel_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <joint name="rl_wheel_joint" type="revolute">
      <pose>-0.11 0.11 0.05 0 0 0</pose>
      <parent>base_link</parent><child>rl_wheel_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <joint name="fr_wheel_joint" type="revolute">
      <pose>0.11 -0.11 0.05 0 0 0</pose>
      <parent>base_link</parent><child>fr_wheel_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <joint name="rr_wheel_joint" type="revolute">
      <pose>-0.11 -0.11 0.05 0 0 0</pose>
      <parent>base_link</parent><child>rr_wheel_link</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <!-- DiffDrive: repeat left/right joints (4 wheels total) -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>fl_wheel_joint</left_joint>
      <left_joint>rl_wheel_joint</left_joint>
      <right_joint>fr_wheel_joint</right_joint>
      <right_joint>rr_wheel_joint</right_joint>

      <wheel_separation>0.22</wheel_separation>
      <wheel_radius>0.05</wheel_radius>

      <!-- If you omit <topic>, default is /model/<name>/cmd_vel -->
      <odom_topic>odometry</odom_topic>
      <max_linear_velocity>1.0</max_linear_velocity>
      <max_angular_velocity>3.0</max_angular_velocity>
    </plugin>
  </model>
</sdf>
